# --- Core GCP ---
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Bucket for uploaded images and generated candidates (Gecko reads from here).
# Name only or gs:// — both accepted.
CANDIDATE_BUCKET=your-bucket-name

# --- Models ---
# Orchestrator LLM (turns tool JSON into A2UI JSON)
GOOGLE_GENAI_MODEL=gemini-3.5-flash
# Image generation model (Nano Banana 2, served on the global endpoint)
IMAGE_MODEL=gemini-3.1-flash-image
GENERATION_LOCATION=global
# Description / refinement model used by the eval wrapper (served on `global`)
DESCRIPTION_MODEL=gemini-3.5-flash
DESCRIPTION_LOCATION=global

# --- Eval loop ---
PASSING_THRESHOLD=0.7
MAX_RETRIES=3
MEDIA_TYPE=image

# --- Optional: signed-URL signing service account (compute/ADC environments) ---
# SIGNING_SA_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# --- Deployment (DEFERRED — only needed when you run deploy.py later) ---
# STORAGE_BUCKET=gs://your-staging-bucket
# GEMINI_ENTERPRISE_APP_ID=your-gemini-enterprise-app-id
# AGENT_AUTHORIZATION=projects/NUMBER/locations/global/authorizations/AUTH_ID
