{
  "messages": [
    {
      "version": "v0.9",
      "createSurface": {
        "surfaceId": "gcs-browser",
        "catalogId": "https://a2ui.org/specification/v0_9/catalogs/basic/catalog.json",
        "sendDataModel": true,
        "theme": {
          "primaryColor": "#135bec"
        }
      }
    },
    {
      "version": "v0.9",
      "updateComponents": {
        "surfaceId": "gcs-browser",
        "components": [
          {
            "id": "root",
            "component": "Column",
            "children": [
              "title",
              "image-list"
            ],
            "align": "stretch"
          },
          {
            "id": "title",
            "component": "Text",
            "text": "Select a reference image",
            "variant": "h2"
          },
          {
            "id": "image-list",
            "component": "List",
            "children": {
              "componentId": "image-card",
              "path": "/images"
            }
          },
          {
            "id": "image-card",
            "component": "Card",
            "child": "card-row"
          },
          {
            "id": "card-row",
            "component": "Row",
            "children": [
              "thumb",
              "card-name",
              "select-btn"
            ],
            "align": "center"
          },
          {
            "id": "thumb",
            "component": "Image",
            "url": {
              "path": "url"
            },
            "fit": "cover",
            "variant": "smallFeature"
          },
          {
            "id": "card-name",
            "component": "Text",
            "text": {
              "path": "name"
            },
            "variant": "h4"
          },
          {
            "id": "select-btn-label",
            "component": "Text",
            "text": "Generate and Evaluate"
          },
          {
            "id": "select-btn",
            "component": "Button",
            "child": "select-btn-label",
            "variant": "primary",
            "action": {
              "event": {
                "name": "select_reference",
                "context": {
                  "referenceUri": {
                    "path": "gs_uri"
                  },
                  "name": {
                    "path": "name"
                  }
                }
              }
            }
          }
        ]
      }
    },
    {
      "version": "v0.9",
      "updateDataModel": {
        "surfaceId": "gcs-browser",
        "path": "/",
        "value": {
          "images": [
            {
              "name": "sneaker_front.png",
              "gs_uri": "gs://my-bucket/products/sneaker_front.png",
              "url": "https://storage.example.com/signed/sneaker_front.png"
            },
            {
              "name": "sneaker_side.png",
              "gs_uri": "gs://my-bucket/products/sneaker_side.png",
              "url": "https://storage.example.com/signed/sneaker_side.png"
            }
          ]
        }
      }
    }
  ]
}
