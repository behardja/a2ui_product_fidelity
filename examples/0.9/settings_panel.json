{
  "messages": [
    {
      "version": "v0.9",
      "createSurface": {
        "surfaceId": "eval-settings",
        "catalogId": "https://a2ui.org/specification/v0_9/catalogs/basic/catalog.json",
        "sendDataModel": true,
        "theme": {
          "primaryColor": "#135bec"
        }
      }
    },
    {
      "version": "v0.9",
      "updateComponents": {
        "surfaceId": "eval-settings",
        "components": [
          {
            "id": "root",
            "component": "Card",
            "child": "col"
          },
          {
            "id": "col",
            "component": "Column",
            "children": [
              "title",
              "sub",
              "ref",
              "thr-label",
              "thr",
              "ret-label",
              "ret",
              "prompt",
              "run"
            ],
            "align": "stretch"
          },
          {
            "id": "title",
            "component": "Text",
            "text": "Evaluation settings",
            "variant": "h2"
          },
          {
            "id": "sub",
            "component": "Text",
            "text": "Adjust these, then run. Defaults come from the server config.",
            "variant": "caption"
          },
          {
            "id": "ref",
            "component": "TextField",
            "label": "Reference gs:// URI",
            "value": {
              "path": "/referenceUri"
            }
          },
          {
            "id": "thr-label",
            "component": "Text",
            "text": "Passing threshold (0-1)",
            "variant": "caption"
          },
          {
            "id": "thr",
            "component": "Slider",
            "value": {
              "path": "/threshold"
            },
            "min": 0,
            "max": 1
          },
          {
            "id": "ret-label",
            "component": "Text",
            "text": "Max attempts",
            "variant": "caption"
          },
          {
            "id": "ret",
            "component": "Slider",
            "value": {
              "path": "/maxRetries"
            },
            "min": 1,
            "max": 5
          },
          {
            "id": "prompt",
            "component": "TextField",
            "label": "Creative direction (optional)",
            "value": {
              "path": "/userPrompt"
            }
          },
          {
            "id": "run-label",
            "component": "Text",
            "text": "Run evaluation"
          },
          {
            "id": "run",
            "component": "Button",
            "child": "run-label",
            "variant": "primary",
            "action": {
              "event": {
                "name": "run_eval",
                "context": {
                  "referenceUri": {
                    "path": "/referenceUri"
                  },
                  "threshold": {
                    "path": "/threshold"
                  },
                  "maxRetries": {
                    "path": "/maxRetries"
                  },
                  "userPrompt": {
                    "path": "/userPrompt"
                  }
                }
              }
            }
          }
        ]
      }
    },
    {
      "version": "v0.9",
      "updateDataModel": {
        "surfaceId": "eval-settings",
        "path": "/",
        "value": {
          "referenceUri": "gs://my-bucket/products/sneaker.png",
          "threshold": 0.7,
          "maxRetries": 3,
          "userPrompt": ""
        }
      }
    }
  ]
}
