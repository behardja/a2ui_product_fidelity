{
  "messages": [
    {
      "version": "v0.9",
      "createSurface": {
        "surfaceId": "fidelity-result",
        "catalogId": "https://a2ui.org/specification/v0_9/catalogs/basic/catalog.json",
        "theme": { "primaryColor": "#135bec" }
      }
    },
    {
      "version": "v0.9",
      "updateComponents": {
        "surfaceId": "fidelity-result",
        "components": [
          { "id": "root", "component": "Column", "children": ["title", "status", "compare", "verdict-tabs"], "align": "stretch" },
          { "id": "title", "component": "Text", "text": "Fidelity Report", "variant": "h2" },
          { "id": "status", "component": "Text", "text": "✅ PASS · Score 0.82 · 2 attempts", "variant": "h3" },

          { "id": "compare", "component": "Row", "children": ["ref-card", "cand-card"], "justify": "center" },
          { "id": "ref-card", "component": "Card", "child": "ref-col" },
          { "id": "ref-col", "component": "Column", "children": ["ref-cap", "ref-img"], "align": "center" },
          { "id": "ref-cap", "component": "Text", "text": "Reference", "variant": "caption" },
          { "id": "ref-img", "component": "Image", "url": "https://storage.example.com/signed/reference.png", "fit": "contain", "variant": "largeFeature" },
          { "id": "cand-card", "component": "Card", "child": "cand-col" },
          { "id": "cand-col", "component": "Column", "children": ["cand-cap", "cand-img"], "align": "center" },
          { "id": "cand-cap", "component": "Text", "text": "Best candidate · attempt 2", "variant": "caption" },
          { "id": "cand-img", "component": "Image", "url": "https://storage.example.com/signed/candidate.png", "fit": "contain", "variant": "largeFeature" },

          { "id": "verdict-tabs", "component": "Tabs", "tabs": [
            { "title": "Passing (2)", "child": "passing-list" },
            { "title": "Failing (1)", "child": "failing-list" },
            { "title": "Scores", "child": "scores-list" }
          ] },

          { "id": "passing-list", "component": "List", "children": { "componentId": "passing-item", "path": "/passing" } },
          { "id": "passing-item", "component": "Row", "children": ["passing-mark", "passing-text"], "align": "center" },
          { "id": "passing-mark", "component": "Text", "text": "✅" },
          { "id": "passing-text", "component": "Text", "text": { "path": "text" } },

          { "id": "failing-list", "component": "List", "children": { "componentId": "failing-item", "path": "/failing" } },
          { "id": "failing-item", "component": "Row", "children": ["failing-mark", "failing-text"], "align": "center" },
          { "id": "failing-mark", "component": "Text", "text": "❌" },
          { "id": "failing-text", "component": "Text", "text": { "path": "text" } },

          { "id": "scores-list", "component": "List", "children": { "componentId": "score-row", "path": "/attempts" } },
          { "id": "score-row", "component": "Row", "children": ["score-label", "score-value"], "justify": "spaceBetween" },
          { "id": "score-label", "component": "Text", "text": { "path": "label" } },
          { "id": "score-value", "component": "Text", "text": { "path": "score" }, "variant": "h4" }
        ]
      }
    },
    {
      "version": "v0.9",
      "updateDataModel": {
        "surfaceId": "fidelity-result",
        "path": "/",
        "value": {
          "attempts": [
            { "label": "Attempt 1", "score": "0.61" },
            { "label": "Attempt 2", "score": "0.82" }
          ],
          "passing": [
            { "text": "Product is a white low-top sneaker" },
            { "text": "Visible red logo on the heel" }
          ],
          "failing": [
            { "text": "Laces should be flat, not round" }
          ]
        }
      }
    }
  ]
}
